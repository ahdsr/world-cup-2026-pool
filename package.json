{
  "name": "world-cup-2026-pool",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node tests/scoring.test.mjs && node tests/leaderboard.test.mjs && node tests/picks-audit.test.mjs && node tests/updater.test.mjs && node tests/update-results-cron.test.mjs",
    "worker:dev": "wrangler dev --config workers/update-results-cron/wrangler.toml",
    "worker:deploy": "wrangler deploy --config workers/update-results-cron/wrangler.toml",
    "worker:deploy:dry-run": "wrangler deploy --dry-run --config workers/update-results-cron/wrangler.toml",
    "worker:secret:github": "wrangler secret put GITHUB_TOKEN --config workers/update-results-cron/wrangler.toml",
    "worker:secret:run": "wrangler secret put RUN_TOKEN --config workers/update-results-cron/wrangler.toml"
  },
  "devDependencies": {
    "wrangler": "^4.100.0"
  }
}
